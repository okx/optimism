# ==============================================================================
# xlayer-node devnet environment
# Copy to .env and fill in values. .env is gitignored — never commit it.
# ==============================================================================

# L1 devnet (managed by docker/docker-compose.devnet.yml)
L1_RPC_URL=http://localhost:8545
L1_BEACON_URL=http://localhost:3500
L1_CHAIN_ID=1337

# L2 node
L2_RPC_URL=http://localhost:8123
L2_ROLLUP_RPC_URL=http://localhost:9545
L2_CHAIN_ID=195

# xlayer-node runtime
XLAYER_DATA_DIR=/tmp/xlayer-data
XLAYER_LOG_LEVEL=info
XLAYER_HTTP_API=eth,net,web3,miner,debug

# L2 JWT secret file path (generate with: openssl rand -hex 32 > config/devnet/jwt.txt)
JWT_SECRET_FILE=config/devnet/jwt.txt

# Docker image tags
OP_STACK_IMAGE_TAG=op-stack:latest

# Devnet private keys (Foundry test accounts — NOT for production use)
RICH_L1_PRIVATE_KEY=0x4bbbf85ce3377467afe5d46f804f221813b2bb87f24d81f60f1fcdbf7cbf4356
OP_BATCHER_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
OP_PROPOSER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
OP_CHALLENGER_PRIVATE_KEY=0x8b3a350cf5c34c9194ca9aa3f146b2b9afed22cd83d3c5f6a3f2f243ce220c01

# Test transaction keys (any funded account on L2)
TEST_SENDER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
TEST_RECIPIENT=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# op-batcher settings (devnet: fast; production: increase these)
BATCHER_MAX_CHANNEL_DURATION=10
BATCHER_NUM_CONFIRMATIONS=1
