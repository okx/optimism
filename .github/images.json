{
  "shared_paths": [
    "docker-bake.hcl",
    ".github/workflows/build-images.yaml",
    ".github/images.json",
    ".github/actions/docker-build-prep/**",
    "ops/scripts/compute-git-versions.sh"
  ],
  "shared_go_paths": [
    "go.mod",
    "go.sum",
    "ops/docker/op-stack-go/**",
    "op-service/**",
    "op-core/**",
    "op-chain-ops/**"
  ],
  "images": {
    "op-node": {
      "type": "go",
      "check": "go",
      "mode": "bake",
      "bake_file": "docker-bake.hcl",
      "target": "op-node",
      "paths": ["op-node/**"]
    },
    "op-batcher": {
      "type": "go",
      "check": "go",
