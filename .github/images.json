    "op-reth": {
      "type": "rust",
      "check": "rust",
      "mode": "bake",
      "bake_file": "docker-bake.hcl",
      "target": "op-reth",
      "paths": ["rust/**"]
    },
    "op-rbuilder": {
      "type": "rust",
      "check": "rust",
      "mode": "bake",
      "bake_file": "docker-bake.hcl",
      "target": "op-rbuilder",
      "paths": ["rust/**"]
    },
    "rollup-boost": {
      "type": "rust",
      "check": "rust",
      "mode": "bake",
      "bake_file": "docker-bake.hcl",
      "target": "rollup-boost",
