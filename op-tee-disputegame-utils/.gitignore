# =============================================================================
# TEE-based DKIM Key Oracle ZK Prover - Git Ignore File
# =============================================================================

# -----------------------------------------------------------------------------
# Rust 编译产物
# -----------------------------------------------------------------------------
/target/                    # Cargo 构建目录
**/*.rs.bk                  # Rust 备份文件
Cargo.lock                  # 对于库项目通常忽略，但应用项目保留

# -----------------------------------------------------------------------------
# RISC Zero 相关文件
# -----------------------------------------------------------------------------
/methods/target/            # methods 子项目构建目录
/host/target/               # host 子项目构建目录
/simple-zk-test/target/     # simple-zk-test 构建目录
/target/riscv-guest/        # RISC Zero guest 构建目录
*.elf                       # RISC Zero ELF 文件
methods/src/lib.rs          # 自动生成的 methods 库文件

# -----------------------------------------------------------------------------
# 测试和日志文件
# -----------------------------------------------------------------------------
*.log                       # 所有日志文件
service.log                 # 服务日志文件
test_*.log                  # 测试日志文件
*.out                       # 输出文件

# -----------------------------------------------------------------------------
# 临时和缓存文件
# -----------------------------------------------------------------------------
.DS_Store                   # macOS 系统文件
.DS_Store?                  # macOS 系统文件变体
._*                         # macOS 资源分支文件
.Spotlight-V100             # macOS Spotlight 索引
.Trashes                    # macOS 回收站
ehthumbs.db                 # Windows 缩略图缓存
Thumbs.db                   # Windows 缩略图缓存

# -----------------------------------------------------------------------------
# IDE 和编辑器文件
# -----------------------------------------------------------------------------
.vscode/                    # VS Code 配置
.idea/                      # IntelliJ IDEA 配置
*.swp                       # Vim 交换文件
*.swo                       # Vim 交换文件
*~                          # 编辑器备份文件
.#*                         # Emacs 锁定文件

# -----------------------------------------------------------------------------
# 密钥和敏感文件
# -----------------------------------------------------------------------------
*.key                       # 私钥文件
*.pem                       # PEM 格式密钥
*.p12                       # PKCS#12 证书
*.pfx                       # PFX 证书
.env                        # 环境变量文件
.env.local                  # 本地环境变量
secrets/                    # 密钥目录
keys/                       # 密钥目录 (除了加密的测试密钥)
!keys/*.enc                 # 但保留加密的测试密钥

# -----------------------------------------------------------------------------
# 测试数据和临时文件
# -----------------------------------------------------------------------------
/testdata/*.bin             # 二进制测试数据
/testdata/*.tmp             # 临时测试文件
test_output/                # 测试输出目录
coverage/                   # 代码覆盖率报告

# -----------------------------------------------------------------------------
# 依赖和包管理
# -----------------------------------------------------------------------------
node_modules/               # Node.js 依赖 (如果有前端组件)
*.tgz                       # 压缩包
*.tar.gz                    # 压缩包

# -----------------------------------------------------------------------------
# 构建和发布文件
# -----------------------------------------------------------------------------
/dist/                      # 发布目录
/build/                     # 构建目录
*.deb                       # Debian 包
*.rpm                       # RPM 包
*.dmg                       # macOS 磁盘镜像
*.exe                       # Windows 可执行文件

# -----------------------------------------------------------------------------
# 文档生成文件
# -----------------------------------------------------------------------------
/doc/                       # 生成的文档
/docs/build/                # 文档构建目录

# -----------------------------------------------------------------------------
# 性能分析和调试文件
# -----------------------------------------------------------------------------
*.prof                      # 性能分析文件
*.pprof                     # Go 性能分析文件
perf.data*                  # Linux 性能分析数据
flamegraph.svg              # 火焰图
callgrind.out.*             # Valgrind 输出

# -----------------------------------------------------------------------------
# 特定于项目的忽略项
# -----------------------------------------------------------------------------
/attestation_cache/         # 证明缓存目录
/proof_cache/               # 证明缓存目录
*.seal                      # ZK 证明 seal 文件
*.journal                   # ZK 证明 journal 文件
benchmark_results.json      # 基准测试结果

# -----------------------------------------------------------------------------
# 开发工具配置
# -----------------------------------------------------------------------------
.cargo/config               # Cargo 本地配置
.rustfmt.toml              # Rustfmt 配置 (项目级别)
.clippy.toml               # Clippy 配置

# =============================================================================
# 保留的重要文件 (显式不忽略)
# =============================================================================
!Cargo.toml                 # 保留所有 Cargo.toml 文件
!README.md                  # 保留 README 文件
!.gitignore                 # 保留 gitignore 文件本身
!Makefile                   # 保留 Makefile
!*.sh                       # 保留 shell 脚本
!*.py                       # 保留 Python 脚本

*.log
.env
program_info.json
proof_result.json
target/