pragma solidity 0.8.15;

// Scripts
import { Script } from "forge-std/Script.sol";
import { VmSafe } from "forge-std/Vm.sol";

// Libraries
import { NetworkUpgradeTxns } from "src/libraries/NetworkUpgradeTxns.sol";
import { Constants } from "src/libraries/Constants.sol";
import { UpgradeUtils } from "scripts/libraries/UpgradeUtils.sol";
import { console2 as console } from "forge-std/console2.sol";

/// @title ExecuteNUTBundle
/// @notice Executes Network Upgrade Transaction (NUT) bundles on a forked L2 chain.
/// @dev This script is designed to be used in fork testing to execute upgrade bundles
///      generated by GenerateNUTBundle stored in the current bundle json file.
contract ExecuteNUTBundle is Script {
    /// @notice Deposit-like wrapper transaction for calls that need mint and/or value.
    /// @param from Address to execute the wrapper call from.
    /// @param to Address to execute the wrapper call against.
    /// @param data Calldata for the wrapper call.
    /// @param gasLimit Deposit gas limit for the wrapper call.
    /// @param mint ETH to add to `from` before the wrapper call.
    /// @param value ETH value to send with the wrapper call.
    /// @param intent Human-readable description of the wrapper call's purpose.
    struct PostWrapperTxn {
        address from;
        address to;
        bytes data;
        uint64 gasLimit;
        uint128 mint;
        uint128 value;
        string intent;
    }

    /// @notice Executes transactions from the current bundle artifact.
    function execute() public {
        executePath(Constants.CURRENT_BUNDLE_PATH);
    }

    /// @notice Executes transactions from a NUT bundle artifact.
    /// @param _path The path to the NUT bundle artifact.
    function executePath(string memory _path) public {
        console.log("ExecuteNUTBundle: Reading bundle from", _path);
        NetworkUpgradeTxns.NetworkUpgradeTxn[] memory txns = NetworkUpgradeTxns.readArtifact(_path);
        console.log("ExecuteNUTBundle: Loaded", txns.length, "transactions");
        executeAll(txns);
    }

    /// @notice Executes all transactions in a parsed NUT bundle.
    /// @param _txns Array of Network Upgrade Transactions to execute.
    function executeAll(NetworkUpgradeTxns.NetworkUpgradeTxn[] memory _txns) public {
        _executeAll(_txns);
    }

    /// @notice Executes a wrapper transaction with deposit-faithful body gas and value semantics.
    /// @param _w The wrapper transaction to execute.
    function executeWrapper(PostWrapperTxn memory _w) public {
        uint64 intrinsicGas = UpgradeUtils.computeIntrinsicGas(_w.data);
        require(
            _w.gasLimit > intrinsicGas,
            string.concat("ExecuteNUTBundle: wrapper gasLimit < intrinsicGas for ", _w.intent)
        );

        vm.deal(_w.from, _w.from.balance + _w.mint);
        vm.prank(_w.from);
        (bool success, bytes memory returnData) =
            _w.to.call{ gas: _w.gasLimit - intrinsicGas, value: _w.value }(_w.data);

        if (!success) {
            string memory reason = UpgradeUtils.getRevertReason(returnData);
            revert(string.concat("ExecuteNUTBundle: wrapper failed - ", _w.intent, " - ", reason));
        }
    }

    /// @notice Executes a single NUT bundle transaction with deposit-faithful body gas semantics.
    /// @dev Intrinsic gas is deducted from the forwarded amount before the call so the body runs
    ///      with the same budget op-geth gives it in production (gasLimit - intrinsic). Body gas
    ///      is measured via vm.lastCallGas() (callee frame only, net of refunds), excluding CALL
    ///      opcode overhead. This is not the same as op-geth's receipt.gasUsed: op-geth applies
    ///      the EIP-7623 floor post-execution (receipt.gasUsed = max(intrinsic+body, floor)),
    ///      so for txs where execution lands below the floor, receipt.gasUsed will exceed
    ///      intrinsic + bodyGasUsed_.
    /// @param _txn The Network Upgrade Transaction to execute.
    /// @return success_ Whether the call succeeded.
    /// @return returnData_ The return data from the call.
    /// @return bodyGasUsed_ Gas consumed by the contract body, net of refunds, excluding intrinsic.
    /// @return intrinsicGas_ Intrinsic gas cost for this transaction.
    function executeSingle(NetworkUpgradeTxns.NetworkUpgradeTxn memory _txn)
        public
        returns (bool success_, bytes memory returnData_, uint64 bodyGasUsed_, uint64 intrinsicGas_)
    {
        intrinsicGas_ = UpgradeUtils.computeIntrinsicGas(_txn.data);
        require(
            _txn.gasLimit > intrinsicGas_, string.concat("ExecuteNUTBundle: gasLimit < intrinsicGas for ", _txn.intent)
        );

        vm.prank(_txn.from);

        (success_, returnData_) = _txn.to.call{ gas: _txn.gasLimit - intrinsicGas_ }(_txn.data);
        VmSafe.Gas memory gasResult = vm.lastCallGas();
        bodyGasUsed_ = uint64(gasResult.gasTotalUsed);
    }

    /// @notice Executes all transactions in the bundle sequentially.
    ///      Failures are reported with the transaction intent for debugging.
    /// @param _txns Array of Network Upgrade Transactions to execute.
    function _executeAll(NetworkUpgradeTxns.NetworkUpgradeTxn[] memory _txns) internal {
        console.log("ExecuteNUTBundle: Executing", _txns.length, "transactions");

        for (uint256 i = 0; i < _txns.length; i++) {
            NetworkUpgradeTxns.NetworkUpgradeTxn memory txn = _txns[i];

            console.log("");
            console.log("ExecuteNUTBundle: [%s/%s] %s", i + 1, _txns.length, txn.intent);
            console.log("  from:", txn.from);
            console.log("  to:", txn.to);
            console.log("  gasLimit:", txn.gasLimit);

            // Execute the transaction
            (bool success, bytes memory returnData,,) = executeSingle(txn);

            if (!success) {
                // Decode revert reason if available
                string memory revertReason = UpgradeUtils.getRevertReason(returnData);
                console.log("  FAILED:", revertReason);
                revert(string.concat("ExecuteNUTBundle: Transaction failed - ", txn.intent, " - ", revertReason));
            }

            console.log("  SUCCESS");
        }

        console.log("");
        console.log("ExecuteNUTBundle: All transactions executed successfully");
    }
}
